  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="120" posY="240" sizeX="121" sizeY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="// get date now&#xD;&#xA;java.util.Date now = TalendDate.getCurrentDate();&#xD;&#xA;&#xD;&#xA;// endTime: now (formatted)&#xD;&#xA;globalMap.put(&quot;endTime&quot;, TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, now));&#xD;&#xA;&#xD;&#xA;// startTime: now minus 28 days&#xD;&#xA;java.util.Date monthAgo = TalendDate.addDate(now, -28, &quot;dd&quot;);&#xD;&#xA;globalMap.put(&quot;startTime&quot;, TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, monthAgo));&#xD;&#xA;&#xD;&#xA;context.startTime = ((String)globalMap.get(&quot;startTime&quot;));&#xD;&#xA;context.endTime = ((String)globalMap.get(&quot;endTime&quot;));&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Start time: &quot; + context.startTime);&#xD;&#xA;System.out.println(&quot;End time: &quot; + context.endTime);&#xD;&#xA;System.out.println(&quot;Time unit: &quot; + context.timeUnit);&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_2"/>
  </node>
