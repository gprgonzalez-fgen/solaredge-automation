    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//check if the row is not null and status code is in the 200-299 range&#xD;&#xA;if (rowSC.statusCode != null &amp;&amp; rowSC.statusCode >= 200 &amp;&amp; rowSC.statusCode &lt;= 299) {&#xD;&#xA;&#xD;&#xA;     // convert to string and store&#xD;&#xA;     String statusStr = String.valueOf(rowSC.statusCode);&#xD;&#xA;     // success: store status code&#xD;&#xA;     globalMap.put(&quot;API_R_STATUS_CODE&quot;, rowSC.statusCode);&#xD;&#xA;     &#xD;&#xA;     System.out.println(&quot;====RESPONSE====&quot;);&#xD;&#xA;     System.out.println(&quot;statusCode: &quot; + (Integer)globalMap.get(&quot;API_R_STATUS_CODE&quot;));&#xD;&#xA;     System.out.println(&quot;====RESPONSE END====&quot;);&#xD;&#xA;     System.out.println(&quot;&quot;);&#xD;&#xA;} "/>
