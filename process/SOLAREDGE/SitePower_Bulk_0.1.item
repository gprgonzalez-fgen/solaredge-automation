  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="400" posY="600">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="globalMap.put(&quot;MAX_DATE&quot;, rowLD.MAX_DATE);&#xD;&#xA;System.out.println(&quot;Max date from Snowflake: &quot; + rowLD.MAX_DATE);&#xD;&#xA;&#xD;&#xA;// 1. Parse the dates for comparison&#xD;&#xA;java.util.Date lastDate = TalendDate.parseDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, rowLD.MAX_DATE);&#xD;&#xA;java.util.Date today = new java.util.Date();&#xD;&#xA;&#xD;&#xA;// 2. Calculate the gap in days&#xD;&#xA;long diffInMillies = Math.abs(today.getTime() - lastDate.getTime());&#xD;&#xA;long diffInDays = java.util.concurrent.TimeUnit.DAYS.convert(diffInMillies, java.util.concurrent.TimeUnit.MILLISECONDS);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Gap detected: &quot; + diffInDays + &quot; days.&quot;);&#xD;&#xA;&#xD;&#xA;// 3. Validation Logic&#xD;&#xA;if (diffInDays > 28) {&#xD;&#xA;    // Option: Use a tDie or throw an exception to stop the job&#xD;&#xA;    throw new RuntimeException(&quot;ERROR: The gap between Snowflake (&quot; + rowLD.MAX_DATE + &quot;) and today is &quot; + diffInDays + &quot; days. &quot; +&#xD;&#xA;        &quot;Detailed API limit is 28 days. Please run this job in 'isHistorical' mode to backfill this period.&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// 4. If gap is safe (&lt;= 28 days), set the parameters for the API&#xD;&#xA;String api_startTime = TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, lastDate);&#xD;&#xA;String api_endTime = TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, today);&#xD;&#xA;&#xD;&#xA;globalMap.put(&quot;api_startTime&quot;, api_startTime);&#xD;&#xA;globalMap.put(&quot;api_endTime&quot;, api_endTime);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Daily Mode safe to proceed. Range: &quot; + (String)globalMap.get(&quot;api_startTime&quot;) + &quot; to &quot; + (String)globalMap.get(&quot;api_endTime&quot;));"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_1"/>
  </node>
